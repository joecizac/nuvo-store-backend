{
  "info": {
    "name": "Nuvo Delivery Platform",
    "description": "Postman collection for the current Nuvo backend. Responses are wrapped as { success, data, message, errorCode }. Public product APIs return ACTIVE products with available SKUs and SKU-derived priceSummary.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('response uses Nuvo envelope when body is JSON', function () {",
          "  const contentType = pm.response.headers.get('Content-Type') || '';",
          "  if (contentType.includes('application/json') && pm.response.text()) {",
          "    const body = pm.response.json();",
          "    pm.expect(body).to.have.property('success');",
          "    pm.expect(body).to.have.property('message');",
          "  }",
          "});"
        ]
      }
    }
  ],
